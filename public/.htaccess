# Configuration Apache pour Hostinger (Hébergement Mutualisé)
# Gère le routage de l'application React (SPA) et redirige les requêtes API vers PHP

# Empêche l'affichage du contenu des dossiers si index.html n'existe pas
Options -Indexes

# Active le moteur de réécriture
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Redirection de l'ancienne route API Node vers le script PHP natif de Hostinger
  RewriteRule ^api/send-email$ api/send-email.php [L,QSA]

  # Si la ressource demandée correspond à un fichier, dossier ou lien symbolique existant, on la sert directement
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d [OR]
  RewriteCond %{REQUEST_FILENAME} -l
  RewriteRule ^ - [L]

  # Redirige toutes les requêtes de pages vers index.html de manière relative au dossier d'installation.
  # Cela fonctionne automatiquement pour les sous-domaines, sous-dossiers et domaines racines !
  # Plus de configuration manuelle nécessaire pour RewriteBase ou d'index.html absolu !
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Option de repli alternative pour Apache 2.4+ si mod_rewrite n'est pas activé ou disponible
<IfModule !mod_rewrite.c>
  FallbackResource index.html
</IfModule>
