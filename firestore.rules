rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email_verified', false) == true &&
             (request.auth.token.email == 'anges.gildas@gmail.com' ||
              request.auth.token.email == 'gildas@gmail.com');
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userStoreId() {
      return getUserData().get('storeId', '');
    }

    function userRole() {
      return getUserData().get('role', 'cashier');
    }

    function belongsToStore(data) {
      return isBootstrapAdmin() || (
        hasUserDoc() && 
        data.storeId == userStoreId()
      );
    }

    function isAdmin() {
      return isBootstrapAdmin() || (
        hasUserDoc() && 
        userRole() in ['admin', 'manager']
      );
    }

    function hasStoreAccess() {
      return isSignedIn() && (
        isBootstrapAdmin() || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    function canRead(module) {
      return isBootstrapAdmin() || (
        hasUserDoc() && (
          userRole() in ['admin', 'manager'] || 
          getUserData().get('permissions', {}).get(module, {}).get('read', false) == true
        )
      );
    }

    function isLicenseActive() {
      return isBootstrapAdmin() || (
        hasUserDoc() && 
        userStoreId() != "" &&
        exists(/databases/$(database)/documents/storeSettings/$(userStoreId())) &&
        get(/databases/$(database)/documents/storeSettings/$(userStoreId())).data.get('licenseStatus', 'inactive') == 'active'
      );
    }

    function canCreate(module) {
      return isLicenseActive() && (
        isBootstrapAdmin() || (
          hasUserDoc() && (
            userRole() in ['admin', 'manager'] || 
            getUserData().get('permissions', {}).get(module, {}).get('create', false) == true
          )
        )
      );
    }

    function canUpdate(module) {
      return isLicenseActive() && (
        isBootstrapAdmin() || (
          hasUserDoc() && (
            userRole() in ['admin', 'manager'] || 
            getUserData().get('permissions', {}).get(module, {}).get('update', false) == true
          )
        )
      );
    }

    function canDelete(module) {
      return isLicenseActive() && (
        isBootstrapAdmin() || (
          hasUserDoc() && (
            userRole() in ['admin', 'manager'] || 
            getUserData().get('permissions', {}).get(module, {}).get('delete', false) == true
          )
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidChatMessage(data) {
      return data.keys().hasAll(['storeId', 'senderId', 'senderName', 'senderEmail', 'senderRole', 'message', 'timestamp', 'type']) &&
             data.storeId is string && data.storeId.size() <= 128 &&
             data.senderId == request.auth.uid &&
             data.senderName is string && data.senderName.size() <= 200 &&
             data.senderEmail is string && data.senderEmail.size() <= 150 &&
             data.senderRole in ['admin', 'manager', 'cashier', 'super-admin'] &&
             data.message is string && data.message.size() <= 2000 &&
             data.type in ['store', 'broadcast', 'direct'] &&
             (!data.keys().hasAll(['recipientId']) || (data.recipientId is string && data.recipientId.size() <= 128)) &&
             (!data.keys().hasAll(['attachmentName']) || (data.attachmentName is string && data.attachmentName.size() <= 256)) &&
             (!data.keys().hasAll(['attachmentType']) || (data.attachmentType is string && data.attachmentType.size() <= 128)) &&
             (!data.keys().hasAll(['attachmentSize']) || (data.attachmentSize is number)) &&
             (!data.keys().hasAll(['attachmentData']) || (data.attachmentData is string && data.attachmentData.size() <= 1500000));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'storeId', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.storeId is string && data.storeId.size() <= 128 &&
             data.email is string && data.email.size() <= 150 &&
             data.role in ['admin', 'manager', 'cashier'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['storeId', 'barcode', 'name', 'price', 'stock', 'unit']) &&
             data.storeId is string &&
             data.barcode is string && data.barcode.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.unit in ['pcs', 'kg', 'g', 'ml', 'l'];
    }

    match /products/{productId} {
      allow read: if canRead('inventory') && belongsToStore(existing());
      allow list: if canRead('inventory') && belongsToStore(resource.data);
      allow create: if canCreate('inventory') && isValidProduct(incoming()) && belongsToStore(incoming()) && isValidId(productId);
      allow update: if canUpdate('inventory') && belongsToStore(existing()) && (
        // Stock adjustment only (ERP internal logic)
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'updatedAt', 'lastStockAdjustment']) && incoming().stock is number) ||
        // Full update
        (isValidProduct(incoming()) && incoming().storeId == existing().storeId)
      );
      allow delete: if canDelete('inventory') && belongsToStore(existing());
    }

    match /categories/{categoryId} {
      allow read: if canRead('inventory') && belongsToStore(existing());
      allow list: if canRead('inventory') && belongsToStore(resource.data);
      allow write: if canCreate('inventory') && belongsToStore(incoming()) && incoming().name is string && incoming().name.size() <= 100 && isValidId(categoryId);
    }

    function isValidCommande(data) {
      return data.keys().hasAll(['storeId', 'timestamp', 'createdBy', 'totalAmount', 'status', 'number']) &&
             data.storeId is string &&
             data.createdBy is string &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'served', 'completed', 'cancelled'] &&
             data.number is string;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['storeId', 'timestamp', 'cashierId', 'totalAmount', 'paymentMethod']) &&
             data.storeId is string &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.paymentMethod in ['cash', 'card', 'mobile'] &&
             data.cashierId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow read: if (canRead('sales') || canRead('pos')) && belongsToStore(existing());
      allow list: if (canRead('sales') || canRead('pos')) && belongsToStore(resource.data);
      allow create: if canCreate('pos') && isValidSale(incoming()) && belongsToStore(incoming()) && isValidId(saleId);
      allow update: if false; // Immutable sales for LRS integrity
      allow delete: if canDelete('sales') && belongsToStore(existing());

      match /items/{itemId} {
        allow read: if (canRead('sales') || canRead('pos')) && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == userStoreId();
        allow create: if canCreate('pos') && isValidId(itemId);
        allow delete: if canDelete('sales') && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == userStoreId();
      }
    }

    match /systemConfig/{configId} {
      allow read: if true; // Public for login configuration
      allow write: if isBootstrapAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || (hasUserDoc() && isAdmin() && existing().storeId == userStoreId()) || isBootstrapAdmin());
      allow list: if isBootstrapAdmin() || (hasUserDoc() && resource.data.storeId == userStoreId());
      allow create: if isBootstrapAdmin() || 
                      (hasUserDoc() && isAdmin() && incoming().storeId == userStoreId() && incoming().uid == userId && isValidUser(incoming())) || 
                      (isSignedIn() && request.auth.uid == userId && incoming().uid == userId && incoming().role == 'admin' && incoming().isActive == false);
      allow update: if isBootstrapAdmin() || 
                      (hasUserDoc() && isAdmin() && (!existing().keys().hasAll(['storeId']) || existing().storeId == userStoreId()) && incoming().storeId == (existing().keys().hasAll(['storeId']) ? existing().storeId : incoming().storeId)) ||
                      (request.auth.uid == userId && 
                       (!existing().keys().hasAll(['role']) || incoming().role == existing().role) && 
                       (!existing().keys().hasAll(['storeId']) || incoming().storeId == existing().storeId) && 
                       (!existing().keys().hasAll(['isActive']) || incoming().isActive == existing().isActive));
      allow delete: if isBootstrapAdmin() || (hasUserDoc() && isAdmin() && existing().storeId == userStoreId());
    }

    match /storeSettings/{settingsId} {
      // Branding identification is public, detailed settings are protected
      allow get: if true; 
      allow list: if isBootstrapAdmin();
      allow create: if isBootstrapAdmin() || (isSignedIn() && isValidId(settingsId) && (settingsId == request.auth.uid || incoming().get('licenseStatus', 'pending') == 'pending'));
      allow update: if (isBootstrapAdmin()) || (
        hasUserDoc() && isAdmin() && settingsId == userStoreId() && (
          // Store admins can only update brand and contact info, never license fields (ERP PROTECTION)
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'address', 'phone', 'logo', 'logoUrl', 'signatureUrl', 'currency', 'updatedAt', 'operatorNumbers', 'selectedOperators'])
        )
      );
      allow delete: if isBootstrapAdmin();
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['storeId', 'title', 'amount', 'category', 'date']) &&
             data.storeId is string && data.storeId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string && data.date.size() <= 50 &&
             data.amount is number && data.amount >= 0;
    }

    match /expenses/{expenseId} {
      allow read: if canRead('accounting') && belongsToStore(existing());
      allow list: if canRead('accounting') && belongsToStore(resource.data);
      allow create: if canCreate('accounting') && isValidExpense(incoming()) && belongsToStore(incoming()) && isValidId(expenseId);
      allow update: if canUpdate('accounting') && belongsToStore(existing()) && incoming().storeId == existing().storeId && isValidExpense(incoming());
      allow delete: if canDelete('accounting') && belongsToStore(existing());
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['storeId', 'action', 'userId', 'timestamp']) &&
             data.storeId is string && data.storeId.size() <= 128 &&
             data.action is string && data.action.size() <= 500 &&
             data.userId == request.auth.uid;
    }

    match /auditLogs/{logId} {
      allow read: if canRead('reports') && belongsToStore(existing());
      allow list: if canRead('reports') && belongsToStore(resource.data);
      allow create: if isSignedIn() && isValidAuditLog(incoming()) && belongsToStore(incoming()) && isValidId(logId);
      allow update: if false; // Logs are immutable (LRS PROTECTION)
      allow delete: if canDelete('reports') && belongsToStore(existing());
    }

    match /employees/{employeeId} {
      allow read: if canRead('personnel') && belongsToStore(existing());
      allow list: if canRead('personnel') && belongsToStore(resource.data);
      allow create: if canCreate('personnel') && belongsToStore(incoming()) && isValidId(employeeId);
      allow update: if canUpdate('personnel') && belongsToStore(existing()) && incoming().storeId == existing().storeId;
      allow delete: if canDelete('personnel') && belongsToStore(existing());
    }

    match /leaves/{leaveId} {
      allow read: if canRead('personnel') && belongsToStore(existing());
      allow list: if canRead('personnel') && belongsToStore(resource.data);
      allow create: if canCreate('personnel') && belongsToStore(incoming()) && isValidId(leaveId);
      allow update: if canUpdate('personnel') && belongsToStore(existing()) && (
        existing().status == 'pending' || isAdmin()
      );
      allow delete: if canDelete('personnel') && belongsToStore(existing());
    }

    match /payroll/{recordId} {
      allow read: if canRead('personnel') && belongsToStore(existing());
      allow list: if canRead('personnel') && belongsToStore(resource.data);
      allow create: if canCreate('personnel') && belongsToStore(incoming()) && isValidId(recordId);
      allow update: if canUpdate('personnel') && belongsToStore(existing()) && (
        existing().status == 'pending' || isAdmin()
      );
      allow delete: if canDelete('personnel') && belongsToStore(existing());
    }

    match /clients/{clientId} {
      allow read: if (canRead('clients') || canRead('pos')) && belongsToStore(existing());
      allow list: if (canRead('clients') || canRead('pos')) && belongsToStore(resource.data);
      allow create: if (canCreate('clients') || canCreate('pos')) && belongsToStore(incoming()) && isValidId(clientId);
      allow update: if (canUpdate('clients') || canCreate('pos')) && belongsToStore(existing()) && incoming().storeId == existing().storeId;
      allow delete: if canDelete('clients') && belongsToStore(existing());
    }

    match /mobileTransactions/{txId} {
      allow read: if (canRead('pos') || canRead('accounting')) && belongsToStore(existing());
      allow list: if (canRead('pos') || canRead('accounting')) && belongsToStore(resource.data);
      allow create: if canCreate('pos') && belongsToStore(incoming()) && isValidId(txId);
      allow update: if (canUpdate('pos') || isAdmin()) && belongsToStore(existing());
      allow delete: if canDelete('accounting') && belongsToStore(existing());
    }

    match /mobileMoneyFloats/{storeId} {
      allow read: if (canRead('pos') || canRead('accounting')) && (isBootstrapAdmin() || storeId == userStoreId());
      allow write: if (canUpdate('pos') || isAdmin()) && (isBootstrapAdmin() || storeId == userStoreId());
    }

    match /mobileMoneySettings/{storeId} {
      allow read: if (canRead('pos') || canRead('accounting')) && (isBootstrapAdmin() || storeId == userStoreId());
      allow create: if isSignedIn() && isValidId(storeId);
      allow update, delete: if isBootstrapAdmin() || ((canUpdate('pos') || isAdmin()) && storeId == userStoreId());
    }

    match /backups/{backupId} {
      allow read: if isAdmin() && belongsToStore(existing());
      allow create: if isAdmin() && belongsToStore(incoming()) && isValidId(backupId);
      allow update, delete: if isAdmin() && belongsToStore(existing());
    }

    match /connectionHistory/{logId} {
      allow read, list: if isBootstrapAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(logId);
      allow update: if false;
      allow delete: if isBootstrapAdmin();
    }

    match /systemNotifications/{notificationId} {
      allow read, list: if isBootstrapAdmin();
      allow create, update, delete: if false;
    }

    match /chatMessages/{msgId} {
      allow read, list: if isSignedIn() && (
        isBootstrapAdmin() ||
        resource.data.storeId == 'broadcast' ||
        resource.data.type == 'broadcast' ||
        (resource.data.type == 'direct' && (
          resource.data.senderId == request.auth.uid ||
          resource.data.recipientId == request.auth.uid
        )) ||
        (resource.data.storeId == userStoreId() && resource.data.type == 'store')
      );
      
      allow create: if isSignedIn() && isValidChatMessage(incoming()) && isValidId(msgId) && (
        isBootstrapAdmin() || (
          incoming().type == 'direct' && (
            incoming().senderId == request.auth.uid ||
            incoming().recipientId == request.auth.uid
          )
        ) || (
          incoming().storeId == userStoreId() &&
          incoming().type == 'store'
        )
      ) && incoming().timestamp == request.time;
      
      allow update: if isBootstrapAdmin() || (
        isSignedIn() && 
        existing().senderId == request.auth.uid && 
        incoming().senderId == existing().senderId && 
        incoming().storeId == existing().storeId &&
        incoming().message is string && incoming().message.size() <= 2000 &&
        incoming().diff(existing()).affectedKeys().hasOnly(['message', 'updatedAt'])
      );
      
      allow delete: if isBootstrapAdmin() || (
        isSignedIn() && existing().senderId == request.auth.uid
      );
    }

    match /commandes/{commandeId} {
      allow read: if (canRead('pos') || canRead('sales')) && (isBootstrapAdmin() || (isSignedIn() && existing().storeId == userStoreId()));
      allow list: if (canRead('pos') || canRead('sales')) && (isBootstrapAdmin() || (isSignedIn() && resource.data.storeId == userStoreId()));
      allow create: if canCreate('pos') && isValidCommande(incoming()) && (isBootstrapAdmin() || (isSignedIn() && incoming().storeId == userStoreId())) && isValidId(commandeId);
      allow update: if canUpdate('pos') && (isBootstrapAdmin() || (isSignedIn() && existing().storeId == userStoreId() && incoming().storeId == existing().storeId));
      allow delete: if canDelete('pos') && (isBootstrapAdmin() || (isSignedIn() && existing().storeId == userStoreId()));
    }
  }
}
